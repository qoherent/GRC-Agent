{
  "schema_version": "2026-05-14.phase2-scenario-v1",
  "scenario_id": "save_load_lifecycle",
  "graph_id": "fixture_random_bit_generator",
  "initial_user_prompt": "Save a copy of this graph to {save_path}.",
  "scripted_user_turns": [
    {
      "assistant_actions": [
        {
          "tool": "save_graph_explicit",
          "kwargs": {"path": "{save_path}", "overwrite": false}
        },
        {
          "text": "The copied graph was saved to the requested safe path."
        }
      ]
    },
    {
      "user_prompt": "Load the saved copied graph from {save_path}.",
      "assistant_actions": [
        {
          "tool": "load_graph_explicit",
          "kwargs": {"path": "{save_path}"}
        },
        {
          "text": "The saved copy was loaded from the safe working path."
        }
      ]
    }
  ],
  "max_turns": 2,
  "allowed_capabilities": ["R5_SAVE_LOAD"],
  "expected_final_state": {"dirty": false},
  "expected_graph_delta": {"no_content_change": true},
  "expected_validation_status": "any",
  "expected_save_load_behavior": {"save_expected": true, "load_expected": true},
  "forbidden_events": [
    "raw_legacy_tool_call",
    "raw_yaml_mutation",
    "preview_mutation",
    "failed_validation_commit",
    "unsafe_save",
    "unsafe_load",
    "original_graph_mutation"
  ]
}
