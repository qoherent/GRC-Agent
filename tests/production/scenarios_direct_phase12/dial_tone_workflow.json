{
  "schema_version": "2026-05-19.phase12-direct-scenario-v1",
  "scenario_id": "dial_tone_workflow",
  "user_mode": "direct_user",
  "graph_id": "installed_audio_dial_tone",
  "initial_user_prompt": "",
  "scripted_user_turns": [
    {
      "user_prompt": "Inspect and briefly explain the copied dial tone flowgraph."
    },
    {
      "user_prompt": "Set variable `samp_rate` to 48000 on the copied graph."
    },
    {
      "user_prompt": "Add a variable named phase12_gain with value 0.25 to the copied graph."
    },
    {
      "user_prompt": "Use this exact selected option: insert with operation_kind insert_block, dry_run false, connection_id analog_sig_source_x_0:0->blocks_add_xx:0, block_id blocks_throttle2, instance_name blocks_throttle2_phase12, type=float, samples_per_second=48000."
    },
    {
      "user_prompt": "Inspect the copied graph and report the current validation status from the latest verified changes."
    },
    {
      "user_prompt": "Save the copied graph to {save_path}."
    },
    {
      "user_prompt": "Load the saved copied graph from {save_path}."
    },
    {
      "user_prompt": "Inspect the final copied graph state after reload."
    }
  ],
  "max_turns": 8,
  "allowed_capabilities": [
    "R0_READ_ONLY",
    "R1_SET_PARAM_ONLY",
    "R4A_INSERT_BLOCK_ON_CONNECTION",
    "R4C_ADD_VARIABLE",
    "R5_SAVE_LOAD"
  ],
  "expected_transcript_complete": true,
  "expected_final_state": {
    "dirty": false,
    "variables": {
      "samp_rate": "48000",
      "phase12_gain": "0.25"
    },
    "blocks": {
      "present": ["phase12_gain", "blocks_throttle2_phase12"]
    },
    "connections": {
      "present": [
        "analog_sig_source_x_0:0->blocks_throttle2_phase12:0",
        "blocks_throttle2_phase12:0->blocks_add_xx:0"
      ],
      "absent": ["analog_sig_source_x_0:0->blocks_add_xx:0"]
    }
  },
  "expected_graph_delta": {
    "must_include": {
      "added_blocks": ["phase12_gain", "blocks_throttle2_phase12"],
      "removed_connections": ["analog_sig_source_x_0:0->blocks_add_xx:0"],
      "variables": {
        "samp_rate": "48000",
        "phase12_gain": "0.25"
      }
    }
  },
  "expected_turn_graph_deltas": [
    {"turn_index": 0, "no_content_change": true},
    {"turn_index": 1, "must_include": {"variables": {"samp_rate": "48000"}}},
    {"turn_index": 2, "must_include": {"added_blocks": ["phase12_gain"], "variables": {"phase12_gain": "0.25"}}},
    {"turn_index": 3, "must_include": {"added_blocks": ["blocks_throttle2_phase12"], "removed_connections": ["analog_sig_source_x_0:0->blocks_add_xx:0"]}},
    {"turn_index": 4, "no_content_change": true},
    {"turn_index": 5, "no_content_change": true},
    {"turn_index": 6, "no_content_change": true},
    {"turn_index": 7, "no_content_change": true}
  ],
  "expected_validation_status": "any",
  "expected_save_load_behavior": {
    "save_expected": true,
    "load_expected": true
  },
  "forbidden_events": [
    "raw_legacy_tool_call",
    "raw_yaml_mutation",
    "preview_mutation",
    "failed_validation_commit",
    "unsafe_save",
    "unsafe_load",
    "original_graph_mutation"
  ]
}
