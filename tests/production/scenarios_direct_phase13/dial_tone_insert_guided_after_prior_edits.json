{
  "schema_version": "2026-05-19.phase13-direct-scenario-v1",
  "scenario_id": "dial_tone_insert_guided_after_prior_edits",
  "user_mode": "direct_user",
  "graph_id": "installed_audio_dial_tone",
  "initial_user_prompt": "",
  "scripted_user_turns": [
    {
      "user_prompt": "Inspect and briefly explain the copied dial tone flowgraph."
    },
    {
      "user_prompt": "Set variable `samp_rate` to 48000 on the copied graph."
    },
    {
      "user_prompt": "Add a variable named phase13_guided_gain with value 0.25 to the copied graph."
    },
    {
      "user_prompt": "Please insert a throttle block on the connection from the 350 Hz tone source to the add block in the copied graph."
    },
    {
      "user_prompt": "Call change_graph now with operation_kind insert_block, dry_run false, connection_id analog_sig_source_x_0:0->blocks_add_xx:0, block_id blocks_throttle2, instance_name blocks_throttle2_phase13_guided, and insert_params {{type: float, samples_per_second: 48000}}."
    }
  ],
  "max_turns": 5,
  "allowed_capabilities": [
    "R0_READ_ONLY",
    "R1_SET_PARAM_ONLY",
    "R4A_INSERT_BLOCK_ON_CONNECTION",
    "R4C_ADD_VARIABLE"
  ],
  "expected_transcript_complete": true,
  "expected_final_state": {
    "dirty": true,
    "variables": {
      "phase13_guided_gain": "0.25"
    },
    "blocks": {
      "present": ["phase13_guided_gain", "blocks_throttle2_phase13_guided"]
    },
    "connections": {
      "present": [
        "analog_sig_source_x_0:0->blocks_throttle2_phase13_guided:0",
        "blocks_throttle2_phase13_guided:0->blocks_add_xx:0"
      ],
      "absent": ["analog_sig_source_x_0:0->blocks_add_xx:0"]
    }
  },
  "expected_graph_delta": {
    "must_include": {
      "added_blocks": ["blocks_throttle2_phase13_guided", "phase13_guided_gain"],
      "removed_connections": ["analog_sig_source_x_0:0->blocks_add_xx:0"],
      "variables": {
        "phase13_guided_gain": "0.25"
      }
    }
  },
  "expected_turn_graph_deltas": [
    {"turn_index": 0, "no_content_change": true},
    {"turn_index": 2, "must_include": {"added_blocks": ["phase13_guided_gain"], "variables": {"phase13_guided_gain": "0.25"}}},
    {"turn_index": 3, "no_content_change": true},
    {"turn_index": 4, "must_include": {"added_blocks": ["blocks_throttle2_phase13_guided"], "removed_connections": ["analog_sig_source_x_0:0->blocks_add_xx:0"]}}
  ],
  "expected_validation_status": "valid",
  "expected_save_load_behavior": {
    "save_expected": false,
    "load_expected": false
  },
  "forbidden_events": [
    "raw_legacy_tool_call",
    "raw_yaml_mutation",
    "preview_mutation",
    "failed_validation_commit",
    "unsafe_save",
    "unsafe_load",
    "original_graph_mutation"
  ]
}
