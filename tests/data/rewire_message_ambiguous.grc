- name: pdu_0
  id: pdu_random_pdu
  parameters:
    minsize: '50'
    maxsize: '2000'
    mask: '0xFF'
    length_modulo: '2'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate:
    - 8
    - 128
    rotation: 0
