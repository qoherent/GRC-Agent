    log_level: info
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate:
    - 8
    - 56
    rotation: 0
    state: enabled
- name: debug_1
  id: blocks_message_debug
  parameters:
    en_uvec: 'True'
    log_level: info
  states:
    bus_sink: false
