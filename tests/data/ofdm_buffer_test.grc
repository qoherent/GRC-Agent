metadata:
  file_format: 1

options:
  parameters:
    author: ''
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: ''
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: no_gui
    hier_block_src_path: '.:'
    id: ofdm_buffer_test
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: OFDM Buffer Test
    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: packet_len
  id: variable
  parameters:
    comment: 'Packet length in OFDM frames'
    value: '6000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [200, 10]
    rotation: 0
    state: enabled

- name: fft_len
  id: variable
  parameters:
    comment: 'FFT size'
    value: '1024'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [320, 10]
    rotation: 0
    state: enabled

- name: cp_len
  id: variable
  parameters:
    comment: 'Cyclic prefix length'
    value: '72'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [440, 10]
    rotation: 0
    state: enabled

- name: src_0
  id: blocks_vector_source_x
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    repeat: 'True'
    tags: '[]'
    type: complex
    vector: (0,)
    vlen: fft_len
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [50, 200]
    rotation: 0
    state: enabled

- name: ofdm_cp_0
  id: digital_ofdm_cyclic_prefixer
  parameters:
    affinity: ''
    alias: ''
    comment: 'OFDM cyclic prefixer. Required minoutbuf expression: packet_len * (fft_len + cp_len)'
    cp_len: cp_len
    input_size: fft_len
    maxoutbuf: '0'
    minoutbuf: '0'
    rolloff: '0'
    tagname: '"packet_len"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [300, 200]
    rotation: 0
    state: enabled

- name: sink_0
  id: blocks_null_sink
  parameters:
    affinity: ''
    alias: ''
    bus_structure_sink: '[]'
    comment: ''
    num_inputs: '1'
    type: complex
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [550, 200]
    rotation: 0
    state: enabled

connections:
- [src_0, '0', ofdm_cp_0, '0']
- [ofdm_cp_0, '0', sink_0, '0']
