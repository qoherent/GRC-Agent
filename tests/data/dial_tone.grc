options:
    parameters:
        author: Example
        catch_exceptions: 'True'
        category: Custom
        cmake_opt: ''
        comment: ''
        copyright: ''
        description: example flow graph
        gen_cmake: 'On'
        gen_linking: dynamic
        generate_options: qt_gui
        hier_block_src_path: '.:'
        id: dial_tone
        max_nouts: '0'
        output_language: python
        placement: (0,0)
        qt_qss_theme: ''
        realtime_scheduling: ''
        run: 'True'
        run_command: '{python} -u {filename}'
        run_options: prompt
        sizing_mode: fixed
        thread_safe_setters: ''
        title: Dial Tone
        window_size: 1280, 1024
    states:
        bus_sink: false
        bus_source: false
        bus_structure: null
        coordinate:
        - 16
        - 12.0
        rotation: 0
        state: enabled
blocks:
-   name: ampl
    id: variable_qtgui_range
    parameters:
        comment: ''
        gui_hint: 0, 0, 1, 2
        label: Volume
        min_len: '200'
        orient: QtCore.Qt.Horizontal
        rangeType: float
        start: '0'
        step: '.001'
        stop: '.5'
        value: '.4'
        widget: counter_slider
    states:
