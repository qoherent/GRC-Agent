        window_size: 3000,2000
    states:
        bus_sink: false
        bus_source: false
        bus_structure: null
        coordinate:
        - 10
        - 10
        rotation: 0
        state: enabled
blocks:
-   name: dec_cc
    id: variable_cc_decoder_def
    parameters:
        comment: ''
        dim1: '1'
        dim2: '4'
        framebits: frame_size*8
        k: k
        mode: fec.CC_TAILBITING
        ndim: '0'
        padding: 'False'
        polys: polys
        rate: rate
        state_end: '-1'
        state_start: '0'
        value: '"ok"'
    states:
