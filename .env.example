# Qoherent GRC Agent configuration. Copy this file to `.env` and edit:
#   cp .env.example .env
#
# NOTE ON SCOPE: the interactive chat agent's provider/model is chosen from
# the web GUI's settings panel (persisted to src/grc_agent/settings.json, a
# separate gitignored file — not this one) and does NOT read these vars. This
# file is specifically for: the OpenRouter API key (needed by both the GUI's
# "openrouter" provider choice and the two paths below), and default
# embedding models for the catalog/docs vector search + web-result synthesis.

# --- OpenRouter (cloud) -------------------------------------------------------
# Get a key at https://openrouter.ai/. Required if you select "openrouter" as
# the chat provider in the GUI settings panel. Also switches the catalog/docs
# embeddings and web-result synthesis to OpenRouter when set.
OPENROUTER_API_KEY=
# Web-result synthesis model (must support tool/function calling).
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
# Embedding model for the catalog/docs vector search.
OPENROUTER_EMBEDDING_MODEL=text-embedding-3-small

# --- Ollama (local) -----------------------------------------------------------
# Used for embeddings and web-result synthesis whenever OPENROUTER_API_KEY is
# unset. Requires a local Ollama server (http://localhost:11434) with these
# models pulled — the main chat model itself is set separately in the GUI
# settings panel, not here.
#   ollama pull qwen3.6:35b-a3b-q4_K_M
#   ollama pull embeddinggemma:latest
OLLAMA_CHAT_MODEL=qwen3.6:35b-a3b-q4_K_M
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest

# --- Server (optional) -------------------------------------------------------
# Override the host and port the web dashboard listens on.
# GRC_AGENT_HOST=127.0.0.1
# GRC_AGENT_PORT=7932
