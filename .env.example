# GRC Agent configuration. Copy this file to `.env` and edit:
#   cp .env.example .env
#
# `.env` is the single source of truth for model names AND API keys. The GUI
# writes here when you swap backends/models (and reads it at startup), so edits
# made by hand take effect on the next launch.
#
# Two backends are supported. Pick ONE active backend in grc_agent.toml
# ([llama].backend = "ollama" | "openrouter") or via the GUI provider selector.
# Chat and embeddings ride the same backend: OpenRouter mode needs NO local
# Ollama at all; Ollama mode is fully local.

# --- OpenRouter (cloud) -------------------------------------------------------
# Get a key at https://openrouter.ai/. Required only when backend = openrouter.
OPENROUTER_API_KEY=
# Chat model (must support tool/function calling). Browse at https://openrouter.ai/models
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Embedding model. Default is Perplexity's pplx-embed (32K context, $0.004/M tokens).
OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b

# --- Ollama (local) -----------------------------------------------------------
# Required only for the hosted web_search/web_fetch tools on Ollama; leave the
# default for plain chat + embeddings (Ollama ignores the key).
OLLAMA_API_KEY=
# Chat model. Must support tool calling (its chat template needs {{ .Tools }}).
# Pull first:  ollama pull gemma4:e4b-it-qat-120k
# For a large context window, bake num_ctx into a custom Modelfile — Ollama's
# /v1 endpoint ignores per-request num_ctx.
OLLAMA_MODEL=gemma4:e4b-it-qat-120k
# Embedding model. Pull first:  ollama pull embeddinggemma:latest
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest

# --- Optional OpenRouter web-grounding (chat) ---------------------------------
# Web search is on by default on OpenRouter via the `web` plugin (grounded
# answers + cited sources). Each grounded turn incurs credit charges.
# OPENROUTER_WEB_SEARCH=true
# OPENROUTER_WEB_SEARCH_MAX_RESULTS=5
# OPENROUTER_WEB_SEARCH_INCLUDE_DOMAINS=
# OPENROUTER_WEB_SEARCH_EXCLUDE_DOMAINS=
