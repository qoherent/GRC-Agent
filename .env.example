# Qoherent GRC Agent configuration. Copy this file to `.env` and edit:
#   cp .env.example .env
#
# This file is the SINGLE SOURCE OF TRUTH for user-settable chat-agent
# preferences: the active provider, the per-provider chat model names, and the
# cloud API keys. All of these are also editable from the dashboard's model
# selector (which writes them back here), so editing this file by hand and
# editing via the GUI are two views of the same state.
#
# Resolution order for which `.env` is loaded (see grc_agent.settings.env_path):
#   1. GRC_AGENT_ENV env var (explicit path override)
#   2. A `.env` in or above the current working directory (dev workflow)
#   3. ~/.config/grc_agent/.env (stable home for an installed package)
# Restart the app after editing for a model/provider/key change to take effect
# (the chat Agent is built once at startup).

# --- Active chat provider -----------------------------------------------------
# Which provider the interactive chat agent uses. One of:
#   ollama        local Ollama server (http://localhost:11434)
#   ollama_cloud  Ollama Cloud (https://ollama.com/v1) — needs OLLAMA_CLOUD_API_KEY
#   openrouter    OpenRouter (https://openrouter.ai) — needs OPENROUTER_API_KEY
GRC_PROVIDER=ollama

# --- Chat models (one per provider; only GRC_PROVIDER's value is live) --------
# Local Ollama chat model. Pull first: ollama pull qwen3.6:35b-a3b-q4_K_M
OLLAMA_CHAT_MODEL=qwen3.6:35b-a3b-q4_K_M
# Ollama Cloud chat model (any model name available on https://ollama.cloud).
OLLAMA_CLOUD_MODEL=deepseek-v4-flash:cloud
# OpenRouter chat model (browse at https://openrouter.ai/models).
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# --- API keys (cloud providers; written by the GUI's key button) --------------
# Get a key at https://openrouter.ai/. Required when GRC_PROVIDER=openrouter.
OPENROUTER_API_KEY=
# Get a key at https://ollama.cloud. Required when GRC_PROVIDER=ollama_cloud.
OLLAMA_CLOUD_API_KEY=

# --- Embedding models (catalog/docs vector search + web-result synthesis) -----
# These do NOT follow GRC_PROVIDER one-for-one: ollama AND ollama_cloud both
# use the LOCAL Ollama server for embeddings (Ollama Cloud's API exposes no
# /v1/embeddings), so a local `ollama serve` is required for the query_knowledge
# tool whenever GRC_PROVIDER is ollama or ollama_cloud.
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest
OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b

# --- OpenRouter routing knobs (optional) -------------------------------------
OPENROUTER_PROVIDER_ORDER=alibaba
OPENROUTER_ALLOW_FALLBACKS=false

# --- Server (optional) -------------------------------------------------------
# Override the host and port the web dashboard listens on.
# GRC_AGENT_HOST=127.0.0.1
# GRC_AGENT_PORT=7932
