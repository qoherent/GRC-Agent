# ---- Python ----
__pycache__/
*.py[oc]
*.egg-info
build/
dist/
.venv
.ruff_cache/
.pytest_cache/

# Keep the package root clean — source lives under src/
/*.py

# ---- Environment / secrets ----
.env

# ---- Editor / OS ----
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- GRC agent runtime artifacts ----
# Backups, locks, and undo snapshots written next to loaded .grc files
.grc_agent/
# GRC save/restore scratch variants
*.saved.grc
*.restored.grc
*.tmp.grc
*.bak

# Generated vector indexes (per-backend, built on first use — see grc_agent.ingest)
src/grc_agent/vectors/

# Test / scratch output
tests/output/
tmp/

# inspect_graph eval experiment — generated artifacts only, scripts stay tracked
experiments/inspect_eval/raw_outputs/
experiments/inspect_eval/reports/
experiments/inspect_eval/final_findings_and_causes.md

# ---- Local agent/tool working dirs (not shared) ----
.claude/
.opencode/
.cache/
.context/
