# ---- Python ----
__pycache__/
*.py[oc]
*.egg-info
build/
dist/
.venv
.ruff_cache/
.pytest_cache/

# Keep the package root clean — source lives under src/
/*.py

# ---- Environment / secrets ----
.env

# ---- Editor / OS ----
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- GRC agent runtime artifacts ----
# Backups, locks, and undo snapshots written next to loaded .grc files
.grc_agent/
# GRC save/restore scratch variants
*.saved.grc
*.restored.grc
*.tmp.grc

# ---- Test output (generated .md logs from integration test runs) ----
tests/output/

# ---- Local dev planning docs (not part of the shipped project) ----
docs/backlog.md
*.bak
# Persisted chat sessions (SQLite) — local user transcripts, not source
chat_sessions.db

# Generated vector indexes (per-backend, built on first use — see grc_agent.ingest)
src/grc_agent/vectors/

# Test / scratch output
tests/output/
tmp/
playground/


# experiments/*/ eval pipelines — generated artifacts only, scripts stay tracked
experiments/*/raw_outputs/
experiments/*/reports/
experiments/*/final_findings_and_causes.md

# ---- Local agent/tool working dirs (not shared) ----
.claude/
.opencode/
.cache/
.context/
unsloth_compiled_cache/
